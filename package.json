{
  "name": "camera-adjustment-simulation",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jedt3d/camera-adjustment-simulation.git"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:cas": "tsc && vite build --base=/cas/",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "npm run test:run && npm run lint && npm run format:check && npm run build",
    "verify:full": "npm run verify && npm run test:e2e"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.3.5",
    "vitest": "^4.1.5"
  }
}
